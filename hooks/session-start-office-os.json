{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/hooks/office_hook.py\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& \\\"$env:PLUGIN_ROOT\\hooks\\run-python.ps1\\\" \\\"$env:PLUGIN_ROOT\\hooks\\office_hook.py\\\"\"",
            "timeout": 10,
            "statusMessage": "載入 Office OS"
          }
        ]
      }
    ]
  }
}
